# Copy to config/providers.env, chmod 600, and fill only the values you use.
# Cachaza parses this file as KEY=value data. It is never executed.

PDCP_API_KEY=
SHODAN_API_KEY=
CERTSPOTTER_API_KEY=
# Current Censys Platform Personal Access Token (Bearer), never a legacy ID:secret pair.
CENSYS_API_KEY=
# Optional for Starter/Search/Core organization entitlements; Free accounts have no organization ID.
CENSYS_ORG_ID=
# Only for theHarvester's legacy Censys connector; not the native Platform PAT.
CENSYS_API_ID=
CENSYS_API_SECRET=
URLSCAN_API_KEY=

# Optional Subfinder providers
BEVIGIL_API_KEY=
BINARYEDGE_API_KEY=
BUILTWITH_API_KEY=
CHAOS_API_KEY=
FOFA_EMAIL=
FOFA_API_KEY=
FULLHUNT_API_KEY=
GITHUB_TOKEN=
HUNTER_API_KEY=
# Exact API URL shown in the IntelX Account > Developer tab.
# Examples include https://free.intelx.io and https://2.intelx.io; keys are host-specific.
INTELX_HOST=
INTELX_API_KEY=
PASSIVETOTAL_USERNAME=
PASSIVETOTAL_KEY=
SECURITYTRAILS_API_KEY=
VT_API_KEY=
WHOISXML_API_KEY=
ZOOMEYE_HOST=zoomeye.hk
ZOOMEYE_API_KEY=
